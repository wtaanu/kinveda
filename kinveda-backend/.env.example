# ==========================================
# KinVeda Backend - Environment Variables
# ==========================================
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Server
PORT=3001
NODE_ENV=development
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001

# Security Keys (generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# Encryption (AES-256 requires exactly 32 bytes = 64 hex chars)
ENCRYPTION_KEY=REPLACE_WITH_32_BYTE_HEX_KEY
ENCRYPTION_IV=REPLACE_WITH_16_BYTE_HEX_IV

# Database
DB_PATH=./data/kinveda.db

# Admin Access (obfuscated route path — change this to something unique!)
ADMIN_ROUTE_PREFIX=/mgmt-alpha-secure
ADMIN_EMAIL=admin@kinveda.in
ADMIN_PASSWORD=KinVeda@Admin2026!

# Email (SMTP — use Gmail App Password or SendGrid)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Admin notification emails (comma-separated, all will receive chat + SOS alerts)
ADMIN_EMAIL_IDS=admin@kinveda.in,ops@kinveda.in

# Email sender display name
EMAIL_FROM_NAME=KinVeda

# Razorpay (Indian payment gateway — amounts collected in INR)
RAZORPAY_KEY_ID=rzp_live_SWMqW8tn9NHHwB
RAZORPAY_KEY_SECRET=REPLACE_WITH_YOUR_SECRET
RAZORPAY_WEBHOOK_SECRET=REPLACE_WITH_WEBHOOK_SECRET

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=200
AUTH_RATE_LIMIT_MAX=10
CHAT_RATE_LIMIT_MAX=5

# Platform settings
PLATFORM_COMMISSION_PCT=20
JITSI_DOMAIN=meet.jit.si
